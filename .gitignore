# Local Parabix checkout (created by scripts/setup_parabix.sh; never committed)
.deps/

# Build output
build/
**/build/
cmake-build-*/
out/

# Compiled objects / libraries / binaries
*.o
*.a
*.dylib
*.so
*.out

# Benchmark datasets (generated locally; may be large)
benchmarks/data/

# Benchmark output (raw CSV/JSON/TXT are generated; small Markdown summaries
# under results/ are intentionally NOT ignored so a verified summary can be committed)
results/*.csv
results/*.json
results/*.txt

# Python
__pycache__/
*.pyc

# macOS
.DS_Store

# Editor files
.vscode/

# Patch / merge / backup leftovers
*.orig
*.rej
*~

# Temporary files
*.tmp
*.log
