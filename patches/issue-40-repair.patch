+
+void UTF16RepairKernel::generateMultiBlockLogic(
+    KernelBuilder & b,
+    llvm::Value * const /* numOfStrides */) {
+
+    Type * const sizeTy = b.getSizeTy();
+    Type * const i8Ty = b.getInt8Ty();
+    Type * const i64Ty = b.getInt64Ty();
+
+    Value * const ZERO = b.getSize(0);
+    Value * const ONE = b.getSize(1);
+
+    // One errorMarks item corresponds to one complete UTF-16 code unit.
+    Value * const numUnits = b.getAccessibleItemCount("errorMarks");
+
+    // Current positions in each stream.
+    Value * const processedUnits =
+        b.getProcessedItemCount("errorMarks");
+
+    Value * const processedBytes =
+        b.getProcessedItemCount("byteStream");
+
+    // Raw input and output pointers for this invocation.
+    Value * const input =
+        b.getRawInputPointer("byteStream", processedBytes);
+
+    // Pointer to the first errorMarks block used by this invocation.
+    Value * const firstMarkBlock =
+        b.CreateUDiv(processedUnits, b.getSize(b.getBitBlockWidth()));
+
+    BasicBlock * const entry = b.GetInsertBlock();
+    BasicBlock * const loop = b.CreateBasicBlock("repairLoop");
+    BasicBlock * const done = b.CreateBasicBlock("repairDone");
+
+    b.CreateCondBr(
+        b.CreateICmpNE(numUnits, ZERO),
+        loop,
+        done);
+
+    b.SetInsertPoint(loop);
+
+    PHINode * const index = b.CreatePHI(sizeTy, 2);
+    index->addIncoming(ZERO, entry);
+
+    // Absolute code-unit position in errorMarks.
+    Value * const absoluteIndex =
+        b.CreateAdd(processedUnits, index);
+
+    // Locate the bit containing errorMarks[absoluteIndex].
+    Value * const blockNumber =
+        b.CreateUDiv(
+            absoluteIndex,
+            b.getSize(b.getBitBlockWidth()));
+
+    Value * const bitInBlock =
+        b.CreateURem(
+            absoluteIndex,
+            b.getSize(b.getBitBlockWidth()));
+
+    Value * const wordNumber =
+        b.CreateUDiv(bitInBlock, b.getSize(64));
+
+    Value * const bitInWord =
+        b.CreateURem(bitInBlock, b.getSize(64));
+
+    Value * const markBlock =
+        b.loadInputStreamBlock(
+            "errorMarks",
+            ZERO,
+            b.CreateSub(blockNumber, firstMarkBlock));
+
+    Value * const markWords =
+        b.CreateBitCast(
+            markBlock,
+            FixedVectorType::get(
+                i64Ty,
+                b.getBitBlockWidth() / 64));
+
+    Value * const word =
+        b.CreateExtractElement(
+            markWords,
+            b.CreateTrunc(wordNumber, b.getInt32Ty()));
+
+    Value * const shifted =
+        b.CreateLShr(word, b.CreateZExtOrTrunc(bitInWord, i64Ty));
+
+    Value * const marked =
+        b.CreateICmpNE(
+            b.CreateAnd(shifted, ConstantInt::get(i64Ty, 1)),
+            ConstantInt::get(i64Ty, 0));
+
+    // Each code unit occupies two bytes.
+    Value * const byteOffset = b.CreateShl(index, ONE);
+
+    Value * const originalLow =
+        b.CreateLoad(
+            i8Ty,
+            b.CreateGEP(i8Ty, input, byteOffset));
+
+    Value * const originalHigh =
+        b.CreateLoad(
+            i8Ty,
+            b.CreateGEP(
+                i8Ty,
+                input,
+                b.CreateAdd(byteOffset, ONE)));
+
+    // U+FFFD is FD FF in UTF-16LE and FF FD in UTF-16BE.
+    Value * const replacementFirst =
+        b.getInt8(mBigEndian ? 0xFF : 0xFD);
+    Value * const replacementSecond =
+        b.getInt8(mBigEndian ? 0xFD : 0xFF);
+
+    Value * const repairedLow =
+        b.CreateSelect(marked, replacementFirst, originalLow);
+
+    Value * const repairedHigh =
+        b.CreateSelect(marked, replacementSecond, originalHigh);
+
+    Value * const outputOffset =
+        b.CreateAdd(processedBytes, byteOffset);
+
+    Value * const outputLowPtr =
+        b.getRawOutputPointer(
+            "repairedStream",
+            ZERO,
+            outputOffset);
+
+    Value * const outputHighPtr =
+        b.getRawOutputPointer(
+            "repairedStream",
+            ZERO,
+            b.CreateAdd(outputOffset, ONE));
+
+    b.CreateStore(repairedLow, outputLowPtr);
+    b.CreateStore(repairedHigh, outputHighPtr);
+
+    Value * const nextIndex = b.CreateAdd(index, ONE);
+    index->addIncoming(nextIndex, loop);
+
+    b.CreateCondBr(
+        b.CreateICmpNE(nextIndex, numUnits),
+        loop,
+        done);
+
+    b.SetInsertPoint(done);
+}
