+class UTF16RepairKernel final : public MultiBlockKernel {
+public:
+    UTF16RepairKernel(
+        LLVMTypeSystemInterface & ts,
+        StreamSet * const byteStream,
+        StreamSet * const errorMarks,
+        StreamSet * const repairedStream,
+        bool bigEndian = false);
+
+protected:
+    void generateMultiBlockLogic(
+        KernelBuilder & b,
+        llvm::Value * const numOfStrides) override;
+    const bool mBigEndian;
+};
+
+UTF16RepairKernel::UTF16RepairKernel(
+    LLVMTypeSystemInterface & ts,
+    StreamSet * const byteStream,
+    StreamSet * const errorMarks,
+    StreamSet * const repairedStream,
+    bool bigEndian)
+: MultiBlockKernel(
+    ts,
+    "utf16repair",
+    {
+        Binding{"byteStream", byteStream, FixedRate(2), {Linear()}},
+        Binding{"errorMarks", errorMarks, FixedRate(1)}
+    },
+    {
+        Binding{"repairedStream", repairedStream, FixedRate(2)}
+    },
+    {},
+    {},
+    {})
+, mBigEndian(bigEndian) {
