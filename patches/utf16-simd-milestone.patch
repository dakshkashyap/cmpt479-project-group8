+using namespace llvm;
+using namespace codegen;
+using namespace kernel;
+
+static cl::OptionCategory utf16validateOptions("utf16validate Options",
+                                               "UTF-16 validation control options.");
+
+static cl::list<std::string> inputFiles(cl::Positional, cl::desc("<input file ...>"), cl::OneOrMore, cl::cat(utf16validateOptions));
+
+// Select the SIMD validation pipeline instead of the default scalar one. Both
+// pipelines expose the exact same generated function signature
+// (uint64_t(*)(uint32_t fd)) and print identical output; --simd only switches
+// which kernels are wired together, so the scalar kernel remains a byte-identical
+// differential oracle.
+static cl::opt<bool> useSIMD("simd", cl::desc("Use the SIMD UTF-16LE validator (default: scalar)."),
+                             cl::init(false), cl::cat(utf16validateOptions));
+
+// ===========================================================================
+// Scalar milestone (differential oracle) -- DO NOT MODIFY.
+// ===========================================================================
+//
+// Byte-oriented UTF-16LE validator kernel (first correctness milestone).
+//
+// This is a deliberately simple, stateful, serial implementation: it walks the
+// raw byte stream two bytes at a time, interpreting each pair as a little-endian
+// UTF-16 code unit, and counts ill-formed code units. Correctness is prioritized
+// over performance for this milestone.
+//
+// Persistent state carried across segments:
+//   errAccum     -- running count of errors seen so far
+//   pendingHigh  -- true if the previous code unit was a high surrogate that has
+//                   not yet been matched with a low surrogate
+//
+// TODO (future performance milestone): replace this serial scan with SIMD
+// 16-bit-lane range checks (fwCast(16,...), mvmd_slli/mvmd_dslli for the
+// one-lane neighbour shift), emit a per-position error-marker StreamSet(1),
+// and reduce it with PopcountKernel instead of accumulating a scalar here.
+class UTF16ValidatorKernel final : public MultiBlockKernel {
+public:
+    UTF16ValidatorKernel(LLVMTypeSystemInterface & ts, StreamSet * byteStream, Scalar * errorCount);
+private:
+    void generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const numOfStrides) override;
+};
+
+UTF16ValidatorKernel::UTF16ValidatorKernel(LLVMTypeSystemInterface & ts, StreamSet * byteStream, Scalar * errorCount)
+: MultiBlockKernel(ts, "utf16validate",
+// input stream: raw bytes (each UTF-16 code unit is two consecutive bytes).
+// Linear() guarantees the accessible bytes are contiguous for a serial walk.
+{Binding{"byteStream", byteStream, FixedRate(1), Linear()}},
+// output streams: none for this milestone.
+{},
+// input scalars
+{},
+// output scalars
+{Binding{"errorCount", errorCount}},
+// internal (persistent) scalars carried across segments
+{InternalScalar{ts.getSizeTy(), "errAccum"},
+ InternalScalar{ts.getInt1Ty(), "pendingHigh"}}) {
+
+}
+
+void UTF16ValidatorKernel::generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const /* numOfStrides */) {
+    Type * const sizeTy = b.getSizeTy();
+    Type * const i1Ty = b.getInt1Ty();
+    Type * const i16Ty = b.getInt16Ty();
+    Value * const ZERO = b.getSize(0);
+    Value * const ONE = b.getSize(1);
+    Value * const sz_ZERO = ZERO;
+    Value * const sz_ONE = ONE;
+
+    // Load persistent state.
+    Value * const errIn = b.getScalarField("errAccum");
+    Value * const pendIn = b.getScalarField("pendingHigh");
+
+    // Bytes available this invocation, and a code-unit-typed pointer to them.
+    Value * const processed = b.getProcessedItemCount("byteStream");
+    Value * const avail = b.getAccessibleItemCount("byteStream");
+    Value * const numUnits = b.CreateLShr(avail, ONE);            // avail / 2 complete code units
+    Value * const oddByte = b.CreateAnd(avail, ONE);              // 1 iff a single trailing byte
+    Value * const i8base = b.getRawInputPointer("byteStream", processed);
+    Value * const u16base = b.CreatePointerCast(i8base, i16Ty->getPointerTo());
+
+    BasicBlock * const entry = b.GetInsertBlock();
+    BasicBlock * const loop = b.CreateBasicBlock("scanUnits");
+    BasicBlock * const done = b.CreateBasicBlock("scanDone");
+    b.CreateCondBr(b.CreateICmpNE(numUnits, ZERO), loop, done);
+
+    // Serial scan over the complete code units of this segment.
+    b.SetInsertPoint(loop);
+    PHINode * const idx = b.CreatePHI(sizeTy, 2);
+    PHINode * const err = b.CreatePHI(sizeTy, 2);
+    PHINode * const pend = b.CreatePHI(i1Ty, 2);
+    idx->addIncoming(ZERO, entry);
+    err->addIncoming(errIn, entry);
+    pend->addIncoming(pendIn, entry);
+
+    Value * const unit = b.CreateLoad(i16Ty, b.CreateGEP(i16Ty, u16base, idx));
+    Value * const isHigh = b.CreateAnd(b.CreateICmpUGE(unit, b.getInt16(0xD800)),
+                                       b.CreateICmpULE(unit, b.getInt16(0xDBFF)));
+    Value * const isLow  = b.CreateAnd(b.CreateICmpUGE(unit, b.getInt16(0xDC00)),
+                                       b.CreateICmpULE(unit, b.getInt16(0xDFFF)));
+
+    // Branch-free surrogate state machine:
+    //   errAdd  = isLow ? (pend ? 0 : 1)   // low is valid only right after a high
+    //                   : (pend ? 1 : 0)   // a pending high not followed by a low is unmatched
+    //   newPend = isHigh                   // any high awaits a low; anything else clears the pending flag
+    Value * const errAdd = b.CreateSelect(isLow,
+                                          b.CreateSelect(pend, sz_ZERO, sz_ONE),
+                                          b.CreateSelect(pend, sz_ONE, sz_ZERO));
+    Value * const errNext = b.CreateAdd(err, errAdd);
+    Value * const pendNext = isHigh;
+
+    Value * const nextIdx = b.CreateAdd(idx, ONE);
+    idx->addIncoming(nextIdx, loop);
+    err->addIncoming(errNext, loop);
+    pend->addIncoming(pendNext, loop);
+    b.CreateCondBr(b.CreateICmpNE(nextIdx, numUnits), loop, done);
+
+    b.SetInsertPoint(done);
+    PHINode * const errFinal = b.CreatePHI(sizeTy, 2);
+    PHINode * const pendFinal = b.CreatePHI(i1Ty, 2);
+    errFinal->addIncoming(errIn, entry);
+    errFinal->addIncoming(errNext, loop);
+    pendFinal->addIncoming(pendIn, entry);
+    pendFinal->addIncoming(pendNext, loop);
+
+    // End-of-file finalization (only on the final segment):
+    //   - a still-pending high surrogate is unmatched -> one error
+    //   - a single trailing byte is an incomplete code unit -> one error
+    Value * const atEOF = b.isFinal();
+    Value * const danglingHigh = b.CreateAnd(atEOF, pendFinal);
+    Value * const oddTrailing = b.CreateAnd(atEOF, b.CreateICmpNE(oddByte, ZERO));
+    Value * errTotal = b.CreateAdd(errFinal, b.CreateZExt(danglingHigh, sizeTy));
+    errTotal = b.CreateAdd(errTotal, b.CreateZExt(oddTrailing, sizeTy));
+
+    // Once finalized, clear the pending flag so it is not re-counted.
+    Value * const pendStore = b.CreateSelect(atEOF, b.getInt1(false), pendFinal);
+
+    b.setScalarField("errAccum", errTotal);
+    b.setScalarField("pendingHigh", pendStore);
+    b.setScalarField("errorCount", errTotal);
+}
+
+// ===========================================================================
+// SIMD milestone.
+// ===========================================================================
+//
+// LITTLE-ENDIAN SCOPE: this SIMD path is scoped to little-endian *hosts* and
+// little-endian data (UTF-16LE). fwCast(16, ...) reinterprets loaded bytes in
+// host lane order, so a 16-bit-lane view of raw LE bytes is only correct on an
+// LE host (x86-64, aarch64-LE -- all mainstream Parabix targets). A future
+// host-endian-agnostic variant would classify on the high byte alone at fw=8
+// (high byte 0xD8-0xDB => high surrogate, 0xDC-0xDF => low surrogate) and use
+// cc::ByteNumbering to pick the high-byte parity; that is out of scope here.
+//
+// Marker semantics (accurate naming): the SIMD stream produced by
+//     mismatch[j] = isLow[j] XOR isHigh[j-1]
+// is a *pairing-mismatch* marker used for COUNTING. It is NOT always an exact
+// source-position marker of the malformed unit: e.g. a high surrogate followed
+// by a BMP unit produces the mismatch bit at the BMP position, and a dangling
+// final high surrogate is not marked in the stream at all but is counted in the
+// scalar tail. The count is what is exact, not the per-bit source position.
+//
+// Data flow (--simd pipeline):
+//   ReadSourceKernel        -> ByteStream : StreamSet(1,8)
+//   UTF16ValidatorSIMDKernel -> errorCount : scalar
+//
+// This kernel is SELF-CONTAINED: it produces the pipeline's errorCount scalar
+// directly, exactly like the scalar UTF16ValidatorKernel (stream in, scalar out,
+// no stream output). It does NOT hand a scalar to a downstream kernel, because a
+// kernel's output scalar is only available after finalization whereas a kernel's
+// input scalars are consumed at initialization (lib/kernel/pipeline/compiler/
+// codegen/pipeline_logic.cpp:338-343 vs :565) -- so kernel->kernel scalar
+// chaining is impossible and triggers "unable to locate valid output scalar"
+// (lib/kernel/pipeline/compiler/codegen/scalar_logic.cpp:73).
+//
+// The SIMD classification and packing are UNCHANGED; the only difference from a
+// stream-emitting design is that each assembled marker block is reduced with
+// bitblock_popcount into a running errAccum instead of stored, and the scalar
+// tail / EOF errors add into the same accumulator.
+class UTF16ValidatorSIMDKernel final : public MultiBlockKernel {
+public:
+    UTF16ValidatorSIMDKernel(LLVMTypeSystemInterface & ts, StreamSet * byteStream, Scalar * errorCount);
+private:
+    void generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const numOfStrides) override;
+};
+
+UTF16ValidatorSIMDKernel::UTF16ValidatorSIMDKernel(LLVMTypeSystemInterface & ts, StreamSet * byteStream, Scalar * errorCount)
+: MultiBlockKernel(ts, "utf16validateSIMD",
+// input: raw bytes, 2 per code unit. Linear() lets the scalar tail walk raw, and
+// the SIMD fast path reads full blocks via loadInputStreamPack.
+{Binding{"byteStream", byteStream, FixedRate(1), Linear()}},
+// no stream output
+{},
+// input scalars
+{},
+// output scalar: total ill-formed code unit count.
+{Binding{"errorCount", errorCount}},
+// internal (persistent) scalars carried across segments:
+//   pendingHigh -- previous code unit was an unmatched high surrogate (1 bit)
+//   errAccum    -- running total (full-block marker popcounts + scalar-tail
+//                  errors) across segments, WITHOUT the EOF adjustments
+{InternalScalar{ts.getInt1Ty(), "pendingHigh"},
+ InternalScalar{ts.getSizeTy(), "errAccum"}}) {
+
+}
+
+void UTF16ValidatorSIMDKernel::generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const /* numOfStrides */) {
+    // Compile-time guard: this SIMD path assumes a little-endian host.
+#if defined(__BYTE_ORDER__) && defined(__ORDER_LITTLE_ENDIAN__)
+    static_assert(__BYTE_ORDER__ == __ORDER_LITTLE_ENDIAN__,
+                  "utf16validate SIMD path is little-endian-host only for this milestone");
+#endif
+
+    Type * const sizeTy = b.getSizeTy();
+    Type * const i1Ty = b.getInt1Ty();
+    Type * const i16Ty = b.getInt16Ty();
+
+    const unsigned BITS = b.getBitBlockWidth();
+    const unsigned LANES = BITS / 16;                 // 16-bit code-unit lanes per pack
+    // 16 packs (signmask chunks) tile one BITS-wide output marker block exactly:
+    // CHUNKS * LANES = 16 * (BITS/16) = BITS.
+    const unsigned CHUNKS = 16;
+    Type * const iLANESTy = b.getIntNTy(LANES);       // LANES-bit field: one signmask chunk
+    unsigned log2BITS = 0;
+    for (unsigned t = BITS; t > 1; t >>= 1) ++log2BITS;
+
+    FixedVectorType * const vecTy = FixedVectorType::get(i16Ty, LANES);      // <LANES x i16> (isHigh / carry)
+    FixedVectorType * const outTy = FixedVectorType::get(iLANESTy, CHUNKS);  // <16 x iLANES> (one output block)
+    Type * const bitBlockTy = b.getBitBlockType();
+
+    Value * const ZERO = b.getSize(0);
+    Value * const ONE = b.getSize(1);
+
+    // Splat constants for the fw=16 surrogate classification. A code unit is a
+    // high surrogate iff (unit & 0xFC00) == 0xD800, a low surrogate iff
+    // (unit & 0xFC00) == 0xDC00 -- the low byte never affects well-formedness.
+    Constant * const splatFC00 = b.getSplat(LANES, ConstantInt::get(i16Ty, 0xFC00));
+    Constant * const splatD800 = b.getSplat(LANES, ConstantInt::get(i16Ty, 0xD800));
+    Constant * const splatDC00 = b.getSplat(LANES, ConstantInt::get(i16Ty, 0xDC00));
+
+    // Geometry from the accessible byte count (independent of numOfStrides, so a
+    // partial final segment is handled exactly).
+    Value * const avail = b.getAccessibleItemCount("byteStream");
+    Value * const validUnits = b.CreateLShr(avail, ONE);                      // complete code units
+    Value * const fullBlocks = b.CreateLShr(validUnits, b.getSize(log2BITS)); // whole output blocks
+    Value * const tailBase = b.CreateShl(fullBlocks, b.getSize(log2BITS));    // first tail unit index
+
+    Value * const pendIn = b.getScalarField("pendingHigh");                   // i1
+    Value * const errAccumIn = b.getScalarField("errAccum");                  // running total, no EOF
+
+    // Initial carry vector for the first pack: zero <LANES x i16> with the
+    // pending-high bit (all-ones / 0) placed in the TOP lane. mvmd_dslli(...,1)
+    // pulls b's top lane into result lane 0 (see the loop below).
+    Value * const pendI16 = b.CreateSExt(pendIn, i16Ty);
+    Value * const initVec = b.CreateInsertElement(ConstantAggregateZero::get(vecTy),
+                                                  pendI16, b.getInt32(LANES - 1));
+
+    BasicBlock * const entry = b.GetInsertBlock();
+    BasicBlock * const simdLoop = b.CreateBasicBlock("simdLoop");
+    BasicBlock * const afterSIMD = b.CreateBasicBlock("afterSIMD");
+    b.CreateCondBr(b.CreateICmpNE(fullBlocks, ZERO), simdLoop, afterSIMD);
+
+    // --- SIMD fast path: one full BITS-wide marker block per iteration ---
+    b.SetInsertPoint(simdLoop);
+    PHINode * const j = b.CreatePHI(sizeTy, 2);          // output block index
+    PHINode * const prevPhi = b.CreatePHI(vecTy, 2);     // isHigh of the previous pack (top lane = last unit)
+    PHINode * const markPhi = b.CreatePHI(sizeTy, 2);    // running marker popcount this invocation
+    j->addIncoming(ZERO, entry);
+    prevPhi->addIncoming(initVec, entry);
+    markPhi->addIncoming(ZERO, entry);
+
+    Value * curPrev = prevPhi;
+    Value * out = UndefValue::get(outTy);
+    for (unsigned k = 0; k < CHUNKS; ++k) {
+        // Pack (k) of output block (j): 16 packs span 2 input stream blocks of 8
+        // packs each -> blockOffset = 2*j + k/8, packIndex = k%8. Every byte read
+        // here is < avail (fullBlocks*2*BITS <= avail), so it is provably in-bounds.
+        Value * const blkOff = b.CreateAdd(b.CreateShl(j, ONE), b.getSize(k / 8));
+        Value * const pack = b.loadInputStreamPack("byteStream", ZERO, b.getInt32(k % 8), blkOff);
+        Value * const v16 = b.fwCast(16, pack);
+        Value * const masked = b.simd_and(v16, splatFC00);
+        Value * const isHigh = b.simd_eq(16, masked, splatD800);   // all-ones / 0 per lane
+        Value * const isLow  = b.simd_eq(16, masked, splatDC00);
+        // prevHigh[lane] = isHigh[lane-1]; lane 0 <- curPrev's top lane (proven order).
+        Value * const prevHi = b.mvmd_dslli(16, isHigh, curPrev, 1);
+        // pairing-mismatch marker (see class comment) -- one all-ones/0 i16 per lane.
+        Value * const mismatchVec = b.simd_xor(isLow, prevHi);
+        // Pack the LANES lane-signs into a LANES-bit chunk and place it at field k.
+        Value * const sm = b.hsimd_signmask(16, mismatchVec);      // i32, LANES valid bits
+        Value * const chunk = b.CreateZExtOrTrunc(sm, iLANESTy);
+        out = b.CreateInsertElement(out, chunk, b.getInt32(k));
+        curPrev = b.fwCast(16, isHigh);                            // carry to the next pack
+    }
+    // Reduce (do not store): count the mismatch markers in this assembled block.
+    // The packing above is unchanged; bitblock_popcount(out) == popcount of the
+    // marker block a stream + PopcountKernel design would have produced.
+    Value * const blockMarks = b.bitblock_popcount(b.CreateBitCast(out, bitBlockTy));
+    Value * const markNext = b.CreateAdd(markPhi, blockMarks);
+    Value * const nextJ = b.CreateAdd(j, ONE);
+    j->addIncoming(nextJ, b.GetInsertBlock());
+    prevPhi->addIncoming(curPrev, b.GetInsertBlock());
+    markPhi->addIncoming(markNext, b.GetInsertBlock());
+    b.CreateCondBr(b.CreateICmpNE(nextJ, fullBlocks), simdLoop, afterSIMD);
+
+    // --- After the SIMD loop: derive the carry from the last VALID unit ---
+    b.SetInsertPoint(afterSIMD);
+    PHINode * const prevFinal = b.CreatePHI(vecTy, 2);
+    prevFinal->addIncoming(initVec, entry);          // fullBlocks == 0 -> carry is pendIn (initVec top lane)
+    prevFinal->addIncoming(curPrev, simdLoop);       // else -> isHigh of the last pack (top lane = last unit)
+    PHINode * const markFinal = b.CreatePHI(sizeTy, 2);   // full-block marker popcount this invocation
+    markFinal->addIncoming(ZERO, entry);
+    markFinal->addIncoming(markNext, simdLoop);
+    Value * const carryI16 = b.mvmd_extract(16, prevFinal, LANES - 1);
+    Value * const carryBool = b.CreateICmpNE(carryI16, ConstantInt::get(i16Ty, 0));
+
+    // --- Scalar tail: complete code units after the last full SIMD block ---
+    // (Only non-empty on the final segment; raw-pointer reads stay within avail
+    // under Linear(), exactly like the scalar oracle.)
+    Value * const processed = b.getProcessedItemCount("byteStream");
+    Value * const i8base = b.getRawInputPointer("byteStream", processed);
+    Value * const u16base = b.CreatePointerCast(i8base, i16Ty->getPointerTo());
+
+    BasicBlock * const tailLoop = b.CreateBasicBlock("tailLoop");
+    BasicBlock * const tailDone = b.CreateBasicBlock("tailDone");
+    b.CreateCondBr(b.CreateICmpNE(tailBase, validUnits), tailLoop, tailDone);
+
+    b.SetInsertPoint(tailLoop);
+    PHINode * const idx = b.CreatePHI(sizeTy, 2);
+    PHINode * const tErr = b.CreatePHI(sizeTy, 2);
+    PHINode * const pend = b.CreatePHI(i1Ty, 2);
+    idx->addIncoming(tailBase, afterSIMD);
+    tErr->addIncoming(ZERO, afterSIMD);
+    pend->addIncoming(carryBool, afterSIMD);
+
+    Value * const unit = b.CreateLoad(i16Ty, b.CreateGEP(i16Ty, u16base, idx));
+    Value * const tMasked = b.CreateAnd(unit, b.getInt16(0xFC00));
+    Value * const tIsHigh = b.CreateICmpEQ(tMasked, b.getInt16(0xD800));
+    Value * const tIsLow  = b.CreateICmpEQ(tMasked, b.getInt16(0xDC00));
+    Value * const errAdd = b.CreateSelect(tIsLow,
+                                          b.CreateSelect(pend, ZERO, ONE),
+                                          b.CreateSelect(pend, ONE, ZERO));
+    Value * const tErrNext = b.CreateAdd(tErr, errAdd);
+    Value * const pendNext = tIsHigh;
+    Value * const idxNext = b.CreateAdd(idx, ONE);
+    idx->addIncoming(idxNext, tailLoop);
+    tErr->addIncoming(tErrNext, tailLoop);
+    pend->addIncoming(pendNext, tailLoop);
+    b.CreateCondBr(b.CreateICmpNE(idxNext, validUnits), tailLoop, tailDone);
+
+    b.SetInsertPoint(tailDone);
+    PHINode * const tErrFinal = b.CreatePHI(sizeTy, 2);
+    PHINode * const pendFinal = b.CreatePHI(i1Ty, 2);
+    tErrFinal->addIncoming(ZERO, afterSIMD);
+    tErrFinal->addIncoming(tErrNext, tailLoop);
+    pendFinal->addIncoming(carryBool, afterSIMD);
+    pendFinal->addIncoming(pendNext, tailLoop);
+
+    // errAccum accumulates full-block marker popcounts + scalar-tail errors across
+    // all segments, WITHOUT the EOF adjustments (so they are never double-added).
+    Value * const newErrAccum = b.CreateAdd(errAccumIn, b.CreateAdd(markFinal, tErrFinal));
+
+    Value * const atEOF = b.isFinal();
+    Value * const danglingHigh = b.CreateAnd(atEOF, pendFinal);                             // trailing high, no successor
+    Value * const oddByte = b.CreateAnd(atEOF, b.CreateICmpNE(b.CreateAnd(avail, ONE), ZERO)); // incomplete final unit
+    Value * errorTotal = b.CreateAdd(newErrAccum, b.CreateZExt(danglingHigh, sizeTy));
+    errorTotal = b.CreateAdd(errorTotal, b.CreateZExt(oddByte, sizeTy));
+
+    b.setScalarField("errAccum", newErrAccum);
+    // Store the pending-high flag from the last VALID unit; clear it at EOF.
+    Value * const pendStore = b.CreateSelect(atEOF, b.getInt1(false), pendFinal);
+    b.setScalarField("pendingHigh", pendStore);
+    // Output scalar written here in generateMultiBlockLogic (final segment wins),
+    // mirroring the scalar UTF16ValidatorKernel -- the proven in-file pattern for a
+    // stream-consuming kernel that terminates the pipeline with a scalar output.
+    b.setScalarField("errorCount", errorTotal);
+}
+
+typedef uint64_t (*utf16validateFunctionType)(const uint32_t fd);
+
+utf16validateFunctionType utf16validatePipelineGen(CPUDriver & driver) {
+    auto P = CreatePipeline(driver, Input<uint32_t>{"fd"}, Output<uint64_t>{"errorCount"});
+    Scalar * const fileDescriptor = P.getInputScalar("fd");
+    StreamSet * const ByteStream = P.CreateStreamSet(1, 8);
+    P.CreateKernelCall<ReadSourceKernel>(fileDescriptor, ByteStream);
+    if (useSIMD) {
+        // SIMD path: one self-contained kernel produces errorCount directly.
+        P.CreateKernelCall<UTF16ValidatorSIMDKernel>(ByteStream, P.getOutputScalar("errorCount"));
+    } else {
+        // Scalar oracle path (default), unchanged.
+        P.CreateKernelCall<UTF16ValidatorKernel>(ByteStream, P.getOutputScalar("errorCount"));
+    }
+    return reinterpret_cast<utf16validateFunctionType>(P.compile());
+}
+
+void utf16validate(utf16validateFunctionType fn_ptr, const std::string & fileName) {
+    const int fd = open(fileName.c_str(), O_RDONLY);
+    if (LLVM_UNLIKELY(fd == -1)) {
+        std::cerr << "Error: cannot open " << fileName << " for processing. Skipped.\n";
+        return;
+    }
+    const uint64_t errorCount = fn_ptr(fd);
+    close(fd);
+    std::cout << fileName << ": errorCount = " << errorCount << "\n";
+}
+
+int main(int argc, char *argv[]) {
+    codegen::ParseCommandLineOptions(argc, argv, {&utf16validateOptions, codegen::codegen_flags()});
+
+    CPUDriver driver("utf16validate");
+    auto fn_ptr = utf16validatePipelineGen(driver);
+    for (unsigned i = 0; i != inputFiles.size(); ++i) {
+        utf16validate(fn_ptr, inputFiles[i]);
+    }
+    return 0;
+}
