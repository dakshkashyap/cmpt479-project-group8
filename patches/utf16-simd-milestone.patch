+
+#include <toolchain/toolchain.h>
+#include <kernel/pipeline/driver/cpudriver.h>
+#include <kernel/pipeline/program_builder.h>
+#include <kernel/io/source_kernel.h>
+#include <kernel/core/kernel.h>
+#include <kernel/core/kernel_builder.h>
+#include <kernel/core/streamset.h>
+#include <kernel/scan/base.h>          // TwoLevelScanKernel (issue #39 consumer)
+#include <llvm/IR/Constants.h>
+#include <llvm/IR/DerivedTypes.h>
+#include <llvm/Support/CommandLine.h>
+#include <iostream>
+#include <string>
+#include <sys/stat.h>
+#include <fcntl.h>
+#include <unistd.h>
+
+using namespace llvm;
+using namespace codegen;
+using namespace kernel;
+
+static cl::OptionCategory utf16validateOptions("utf16validate Options",
+                                               "UTF-16 validation control options.");
+
+static cl::list<std::string> inputFiles(cl::Positional, cl::desc("<input file ...>"), cl::OneOrMore, cl::cat(utf16validateOptions));
+
+// Select the SIMD validation pipeline instead of the default scalar one. Both
+// pipelines expose the exact same generated function signature
+// (uint64_t(*)(uint32_t fd)) and print identical output; --simd only switches
+// which kernels are wired together, so the scalar kernel remains a byte-identical
+// differential oracle.
+static cl::opt<bool> useSIMD("simd", cl::desc("Use the SIMD UTF-16 validator (default: scalar)."),
+                             cl::init(false), cl::cat(utf16validateOptions));
+
+// Select UTF-16BE input. Default is UTF-16LE, unchanged. Endianness only changes which byte
+// of each code-unit pair is the high byte (2k for BE, 2k+1 for LE); every validator/producer
+// path honours it, and the errorMarks scan consumer is endian-agnostic (it works on code-unit
+// positions). See docs/utf16be_support.md.
+static cl::opt<bool> bigEndian("be", cl::desc("Validate UTF-16BE input (default: UTF-16LE)."),
+                               cl::init(false), cl::cat(utf16validateOptions));
+
+// PROTOTYPE (issue #32). Selects the errorMarks producer pipeline instead of a count-only
+// one: the kernel emits a real StreamSet(1) bitstream with one bit per UTF-16 code unit,
+// set iff that code unit is ill-formed, and still reports the same errorCount. It is a
+// SEPARATE path -- the optimized count-only kernels are untouched and remain the default,
+// so this cannot regress them. There is no repair and no TwoLevelScanKernel subclass.
+static cl::opt<bool> emitErrorMarks("emit-error-marks",
+                                    cl::desc("PROTOTYPE: emit an errorMarks bitstream "
+                                             "(one bit per code unit) instead of counting only."),
+                                    cl::init(false), cl::cat(utf16validateOptions));
+
+// Prints the code-unit index of every set bit in errorMarks, so the emitted bitstream can be
+// diffed against the standalone prototypes. Requires --emit-error-marks. This is the issue #32
+// DEBUG printer: a linear ErrorMarkPositionKernel that visits every block and skips nothing.
+static cl::opt<bool> printPositions("print-positions",
+                                    cl::desc("PROTOTYPE: with --emit-error-marks, print the "
+                                             "code-unit position of every ill-formed unit "
+                                             "(issue #32 linear debug printer)."),
+                                    cl::init(false), cl::cat(utf16validateOptions));
+
+// PROTOTYPE (issue #39). Consumes errorMarks with a real subclass of Parabix's
+// TwoLevelScanKernel: it builds a high-level index (maskHL), SKIPS clean 4096-code-unit
+// regions with a single branch, and scans only dirty scanwords with ctz / reset-lowest-bit.
+// It prints the same "errpos = <hex>" lines as --print-positions (they are the same code-unit
+// positions), so both are diffable against benchmarks/llmask_reference.py --positions; the
+// difference is the SCAN STRATEGY, not the output. Requires --emit-error-marks. Implies a
+// producer + consumer pipeline.
+static cl::opt<bool> scanErrorMarks("scan-error-marks",
+                                    cl::desc("PROTOTYPE: with --emit-error-marks, locate errors "
+                                             "with a TwoLevelScanKernel subclass (skips clean "
+                                             "regions) and print their positions."),
+                                    cl::init(false), cl::cat(utf16validateOptions));
+
+// ===========================================================================
+// Scalar milestone (differential oracle) -- DO NOT MODIFY.
+// ===========================================================================
+//
+// Byte-oriented UTF-16LE validator kernel (first correctness milestone).
+//
+// This is a deliberately simple, stateful, serial implementation: it walks the
+// raw byte stream two bytes at a time, interpreting each pair as a little-endian
+// UTF-16 code unit, and counts ill-formed code units. Correctness is prioritized
+// over performance for this milestone.
+//
+// Persistent state carried across segments:
+//   errAccum     -- running count of errors seen so far
+//   pendingHigh  -- true if the previous code unit was a high surrogate that has
+//                   not yet been matched with a low surrogate
+//
+// The performance path is UTF16ValidatorSIMDKernel (below), which classifies
+// surrogates byte-by-byte at fw=8 on the high byte of each code unit and is
+// therefore independent of host lane order. This scalar kernel is deliberately
+// kept as the differential oracle for it and is not the portable path: it forms
+// each code unit with a host-order 16-bit load, which is correct for the
+// UTF-16LE target on the little-endian hosts we build on.
+// See docs/SIMD_BYTE_ORIENTED_VALIDATOR.md for the byte-oriented design.
+class UTF16ValidatorKernel final : public MultiBlockKernel {
+public:
+    UTF16ValidatorKernel(LLVMTypeSystemInterface & ts, StreamSet * byteStream, Scalar * errorCount,
+                         bool bigEndian = false);
+private:
+    void generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const numOfStrides) override;
+    const bool mBigEndian;
+};
+
+UTF16ValidatorKernel::UTF16ValidatorKernel(LLVMTypeSystemInterface & ts, StreamSet * byteStream, Scalar * errorCount,
+                                           bool bigEndian)
+: MultiBlockKernel(ts, bigEndian ? "utf16validate_be" : "utf16validate",
+// input stream: raw bytes (each UTF-16 code unit is two consecutive bytes).
+// Linear() guarantees the accessible bytes are contiguous for a serial walk.
+{Binding{"byteStream", byteStream, FixedRate(1), Linear()}},
+// output streams: none for this milestone.
+{},
+// input scalars
+{},
+// output scalars
+{Binding{"errorCount", errorCount}},
+// internal (persistent) scalars carried across segments
+{InternalScalar{ts.getSizeTy(), "errAccum"},
+ InternalScalar{ts.getInt1Ty(), "pendingHigh"}})
+, mBigEndian(bigEndian) {
+
+}
+
+void UTF16ValidatorKernel::generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const /* numOfStrides */) {
+    Type * const sizeTy = b.getSizeTy();
+    Type * const i1Ty = b.getInt1Ty();
+    Type * const i16Ty = b.getInt16Ty();
+    Value * const ZERO = b.getSize(0);
+    Value * const ONE = b.getSize(1);
+    Value * const sz_ZERO = ZERO;
+    Value * const sz_ONE = ONE;
+
+    // Load persistent state.
+    Value * const errIn = b.getScalarField("errAccum");
+    Value * const pendIn = b.getScalarField("pendingHigh");
+
+    // Bytes available this invocation, and a code-unit-typed pointer to them.
+    Value * const processed = b.getProcessedItemCount("byteStream");
+    Value * const avail = b.getAccessibleItemCount("byteStream");
+    Value * const numUnits = b.CreateLShr(avail, ONE);            // avail / 2 complete code units
+    Value * const oddByte = b.CreateAnd(avail, ONE);              // 1 iff a single trailing byte
+    Value * const i8base = b.getRawInputPointer("byteStream", processed);
+    Value * const u16base = b.CreatePointerCast(i8base, i16Ty->getPointerTo());
+
+    BasicBlock * const entry = b.GetInsertBlock();
+    BasicBlock * const loop = b.CreateBasicBlock("scanUnits");
+    BasicBlock * const done = b.CreateBasicBlock("scanDone");
+    b.CreateCondBr(b.CreateICmpNE(numUnits, ZERO), loop, done);
+
+    // Serial scan over the complete code units of this segment.
+    b.SetInsertPoint(loop);
+    PHINode * const idx = b.CreatePHI(sizeTy, 2);
+    PHINode * const err = b.CreatePHI(sizeTy, 2);
+    PHINode * const pend = b.CreatePHI(i1Ty, 2);
+    idx->addIncoming(ZERO, entry);
+    err->addIncoming(errIn, entry);
+    pend->addIncoming(pendIn, entry);
+
+    // The raw i16 load is in host order (little-endian on our targets), so it is the true
+    // code unit for UTF-16LE data. For UTF-16BE data the bytes are swapped, so byte-swap the
+    // loaded value to recover the code unit; the identical range checks then follow. The LE
+    // path is byte-for-byte unchanged.
+    Value * const rawUnit = b.CreateLoad(i16Ty, b.CreateGEP(i16Ty, u16base, idx));
+    Value * const unit = mBigEndian
+        ? b.CreateUnaryIntrinsic(Intrinsic::bswap, rawUnit)
+        : rawUnit;
+    Value * const isHigh = b.CreateAnd(b.CreateICmpUGE(unit, b.getInt16(0xD800)),
+                                       b.CreateICmpULE(unit, b.getInt16(0xDBFF)));
+    Value * const isLow  = b.CreateAnd(b.CreateICmpUGE(unit, b.getInt16(0xDC00)),
+                                       b.CreateICmpULE(unit, b.getInt16(0xDFFF)));
+
+    // Branch-free surrogate state machine:
+    //   errAdd  = isLow ? (pend ? 0 : 1)   // low is valid only right after a high
+    //                   : (pend ? 1 : 0)   // a pending high not followed by a low is unmatched
+    //   newPend = isHigh                   // any high awaits a low; anything else clears the pending flag
+    Value * const errAdd = b.CreateSelect(isLow,
+                                          b.CreateSelect(pend, sz_ZERO, sz_ONE),
+                                          b.CreateSelect(pend, sz_ONE, sz_ZERO));
+    Value * const errNext = b.CreateAdd(err, errAdd);
+    Value * const pendNext = isHigh;
+
+    Value * const nextIdx = b.CreateAdd(idx, ONE);
+    idx->addIncoming(nextIdx, loop);
+    err->addIncoming(errNext, loop);
+    pend->addIncoming(pendNext, loop);
+    b.CreateCondBr(b.CreateICmpNE(nextIdx, numUnits), loop, done);
+
+    b.SetInsertPoint(done);
+    PHINode * const errFinal = b.CreatePHI(sizeTy, 2);
+    PHINode * const pendFinal = b.CreatePHI(i1Ty, 2);
+    errFinal->addIncoming(errIn, entry);
+    errFinal->addIncoming(errNext, loop);
+    pendFinal->addIncoming(pendIn, entry);
+    pendFinal->addIncoming(pendNext, loop);
+
+    // End-of-file finalization (only on the final segment):
+    //   - a still-pending high surrogate is unmatched -> one error
+    //   - a single trailing byte is an incomplete code unit -> one error
+    Value * const atEOF = b.isFinal();
+    Value * const danglingHigh = b.CreateAnd(atEOF, pendFinal);
+    Value * const oddTrailing = b.CreateAnd(atEOF, b.CreateICmpNE(oddByte, ZERO));
+    Value * errTotal = b.CreateAdd(errFinal, b.CreateZExt(danglingHigh, sizeTy));
+    errTotal = b.CreateAdd(errTotal, b.CreateZExt(oddTrailing, sizeTy));
+
+    // Once finalized, clear the pending flag so it is not re-counted.
+    Value * const pendStore = b.CreateSelect(atEOF, b.getInt1(false), pendFinal);
+
+    b.setScalarField("errAccum", errTotal);
+    b.setScalarField("pendingHigh", pendStore);
+    b.setScalarField("errorCount", errTotal);
+}
+
+// ===========================================================================
+// SIMD milestone -- byte-oriented (fw=8) high-byte classification.
+// ===========================================================================
+//
+// BYTE-ORIENTED, HOST-ENDIAN AGNOSTIC: this path classifies the raw byte stream
+// at fw=8 and never reinterprets pairs of bytes as 16-bit code units in host
+// lane order. Only the HIGH byte of a code unit decides well-formedness:
+//     (highByte & 0xFC) == 0xD8  => high surrogate (0xD800-0xDBFF)
+//     (highByte & 0xFC) == 0xDC  => low  surrogate (0xDC00-0xDFFF)
+// The low byte is never inspected. This mirrors the high-byte NEON strategy of
+// Clausecker & Lemire and, being byte-level, needs no little-endian *host*
+// guard: we select the high byte of code unit k by memory *position* (byte 2k+1
+// for UTF-16LE), not by host lane significance. UTF-16BE support is the one-line
+// change of selecting the even byte positions instead.
+//
+// The pairing check stays entirely in vector registers: the previous pack's
+// high-surrogate mask is carried as a vector and advanced with mvmd_dslli, and the
+// per-pack count is a single bitblock_popcount. No per-byte mask is extracted to a
+// scalar register in the loop. An earlier version used hsimd_signmask(8, ...) here;
+// on AArch64 that has no NEON lowering in IDISA and expanded into ~16 lane
+// extractions plus scalar bit assembly per call, which dominated the hot loop
+// (see docs/simd_regression_investigation.md).
+//
+// Marker semantics (accurate naming): the quantity counted here is
+//     mismatch[k] = isLow[k] XOR isHigh[k-1]
+// evaluated at each high-byte position. It is a *pairing-mismatch* count, exact
+// for the number of ill-formed code units, but not always an exact per-position
+// marker: a high surrogate followed by a BMP unit registers the mismatch at the
+// BMP position, and a dangling final high surrogate is counted at EOF rather
+// than marked in the stream. The COUNT is what is exact.
+//
+// Data flow (--simd pipeline):
+//   ReadSourceKernel        -> ByteStream : StreamSet(1,8)
+//   UTF16ValidatorSIMDKernel -> errorCount : scalar
+//
+// This kernel is SELF-CONTAINED: it produces the pipeline's errorCount scalar
+// directly, exactly like the scalar UTF16ValidatorKernel (stream in, scalar out,
+// no stream output). It does NOT hand a scalar to a downstream kernel, because a
+// kernel's output scalar is only available after finalization whereas a kernel's
+// input scalars are consumed at initialization (lib/kernel/pipeline/compiler/
+// codegen/pipeline_logic.cpp:338-343 vs :565) -- so kernel->kernel scalar
+// chaining is impossible and triggers "unable to locate valid output scalar"
+// (lib/kernel/pipeline/compiler/codegen/scalar_logic.cpp:73).
+//
+// Per BITS-wide byte pack the mismatch bits are reduced with a scalar popcount
+// into a running errAccum; the byte-oriented scalar tail and EOF errors add into
+// the same accumulator. A single carry bit (was the previous code unit an
+// unmatched high surrogate?) threads across packs, blocks and segments.
+class UTF16ValidatorSIMDKernel final : public MultiBlockKernel {
+public:
+    UTF16ValidatorSIMDKernel(LLVMTypeSystemInterface & ts, StreamSet * byteStream, Scalar * errorCount,
+                             bool bigEndian = false);
+private:
+    void generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const numOfStrides) override;
+    const bool mBigEndian;
+};
+
+UTF16ValidatorSIMDKernel::UTF16ValidatorSIMDKernel(LLVMTypeSystemInterface & ts, StreamSet * byteStream, Scalar * errorCount,
+                                                   bool bigEndian)
+: MultiBlockKernel(ts, bigEndian ? "utf16validateSIMD_be" : "utf16validateSIMD",
+// input: raw bytes, 2 per code unit. Linear() lets the scalar tail walk raw, and
+// the SIMD fast path reads full blocks via loadInputStreamPack.
+{Binding{"byteStream", byteStream, FixedRate(1), Linear()}},
+// no stream output
+{},
+// input scalars
+{},
+// output scalar: total ill-formed code unit count.
+{Binding{"errorCount", errorCount}},
+// internal (persistent) scalars carried across segments:
+//   pendingHigh -- previous code unit was an unmatched high surrogate (1 bit)
+//   errAccum    -- running total (full-block marker popcounts + scalar-tail
+//                  errors) across segments, WITHOUT the EOF adjustments
+{InternalScalar{ts.getInt1Ty(), "pendingHigh"},
+ InternalScalar{ts.getSizeTy(), "errAccum"}})
+, mBigEndian(bigEndian) {
+
+}
+
+void UTF16ValidatorSIMDKernel::generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const /* numOfStrides */) {
+    Type * const sizeTy = b.getSizeTy();
+    Type * const i1Ty = b.getInt1Ty();
+    Type * const i8Ty = b.getInt8Ty();
+
+    // High-byte lane offset within a code unit: UTF-16LE puts the high byte at the ODD
+    // byte position (2k+1), UTF-16BE at the EVEN position (2k). Everything endian-specific
+    // in this kernel reduces to this one offset. LE (HB=1) is byte-for-byte unchanged.
+    const unsigned HB = mBigEndian ? 0u : 1u;
+
+    const unsigned BITS = b.getBitBlockWidth();
+    const unsigned BYTES_PER_PACK = BITS / 8;           // bytes in one SIMD pack
+    const unsigned UNITS_PER_PACK = BITS / 16;          // complete UTF-16 code units per pack
+    const unsigned HIGH_BYTE_POS = BYTES_PER_PACK - 2 + HB;  // last high-byte lane in a pack
+
+    // Byte-lane vector type for one pack. The whole pairing check stays in this type:
+    // nothing is extracted to a scalar bitmask inside the loop.
+    FixedVectorType * const byteVecTy = FixedVectorType::get(i8Ty, BYTES_PER_PACK);
+
+    // ODD_ONE_MASK selects the high-byte position of every code unit: memory byte 2k+HB,
+    // i.e. the odd positions for UTF-16LE (HB=1) or the even positions for UTF-16BE (HB=0).
+    // Selecting by *position* (not by host lane significance) is what makes the
+    // classification host-endian agnostic.
+    //
+    // It leaves a single set bit (0x01) at each selected position rather than a full
+    // 0xFF byte, so one block popcount of the masked mismatch vector is exactly the
+    // number of ill-formed code units -- no per-byte mask extraction is needed.
+    std::vector<Constant *> oddLanes(BYTES_PER_PACK);
+    for (unsigned pos = 0; pos < BYTES_PER_PACK; ++pos) {
+        oddLanes[pos] = ConstantInt::get(i8Ty, ((pos & 1u) == HB) ? 0x01 : 0x00);
+    }
+    Constant * const ODD_ONE_MASK = ConstantVector::get(oddLanes);
+
+    Value * const ZERO = b.getSize(0);
+    Value * const ONE = b.getSize(1);
+
+    // Byte-oriented fw=8 surrogate classification splats. The high byte alone
+    // decides the class: (highByte & 0xFC) == 0xD8 => high surrogate,
+    // == 0xDC => low surrogate. Comparisons are on raw bytes -- no 16-bit
+    // host-order reinterpretation is involved.
+    Value * const splatFC = b.simd_fill(8, b.getInt8(0xFC));
+    Value * const splatD8 = b.simd_fill(8, b.getInt8(0xD8));
+    Value * const splatDC = b.simd_fill(8, b.getInt8(0xDC));
+
+    // Geometry from the accessible byte count (independent of numOfStrides, so a
+    // partial final segment is handled exactly).
+    Value * const avail = b.getAccessibleItemCount("byteStream");
+    Value * const validUnits = b.CreateLShr(avail, ONE);                        // complete code units
+    Value * const fullPacks = b.CreateUDiv(avail, b.getSize(BYTES_PER_PACK));   // whole SIMD packs
+    Value * const tailBase = b.CreateMul(fullPacks, b.getSize(UNITS_PER_PACK)); // first tail unit index
+
+    Value * const pendIn = b.getScalarField("pendingHigh");                     // i1
+    Value * const errAccumIn = b.getScalarField("errAccum");                    // running total, no EOF
+
+    // The carry state -- "was the previous code unit an unmatched high surrogate?" --
+    // is threaded as a *vector*: the previous pack's high-surrogate byte mask. Only its
+    // last high-byte lane matters, so the incoming pendingHigh scalar is injected there
+    // (0xFF = set, matching what simd_eq produces). Keeping the carry in vector form is
+    // what lets the loop shift it with mvmd_dslli instead of extracting a scalar bit.
+    Value * const pendByte = b.CreateSExt(pendIn, i8Ty);            // 0xFF if pending, else 0x00
+    Value * const carryInit = b.CreateInsertElement(ConstantAggregateZero::get(byteVecTy),
+                                                    pendByte, b.getInt32(HIGH_BYTE_POS));
+
+    BasicBlock * const entry = b.GetInsertBlock();
+    BasicBlock * const simdLoop = b.CreateBasicBlock("simdLoop");
+    BasicBlock * const afterSIMD = b.CreateBasicBlock("afterSIMD");
+    b.CreateCondBr(b.CreateICmpNE(fullPacks, ZERO), simdLoop, afterSIMD);
+
+    // --- SIMD fast path: one BITS-wide byte pack (UNITS_PER_PACK code units) per
+    // iteration. Linear pack index p addresses (packIndex = p % 8, blockOffset =
+    // p / 8), the stream-pack layout used throughout the Parabix byte kernels.
+    // Every byte read is < avail (fullPacks*BYTES_PER_PACK <= avail), in-bounds. ---
+    b.SetInsertPoint(simdLoop);
+    PHINode * const p = b.CreatePHI(sizeTy, 2);              // pack index
+    PHINode * const prevHiPhi = b.CreatePHI(byteVecTy, 2);   // previous pack's high-surrogate mask
+    PHINode * const markPhi = b.CreatePHI(sizeTy, 2);        // running mismatch count this invocation
+    p->addIncoming(ZERO, entry);
+    prevHiPhi->addIncoming(carryInit, entry);
+    markPhi->addIncoming(ZERO, entry);
+
+    Value * const packIndex = b.CreateTrunc(b.CreateAnd(p, b.getSize(7)), b.getInt32Ty());
+    Value * const blockOffset = b.CreateLShr(p, b.getSize(3));
+    Value * const pack = b.loadInputStreamPack("byteStream", ZERO, packIndex, blockOffset);
+
+    // Classify every byte at fw=8. The high byte alone decides the class:
+    //   (highByte & 0xFC) == 0xD8 -> high surrogate,  == 0xDC -> low surrogate.
+    // simd_eq yields an all-ones (0xFF) byte at each matching position.
+    Value * const bytes = b.fwCast(8, pack);
+    Value * const masked = b.simd_and(bytes, splatFC);
+    Value * const isHi8 = b.simd_eq(8, masked, splatD8);
+    Value * const isLo8 = b.simd_eq(8, masked, splatDC);
+
+    // Pairing check, performed entirely in vector registers:
+    //     mismatch[k] = isLow[k] XOR isHigh[k-1]
+    //
+    // "isHigh of the previous code unit" is isHi8 advanced by one code unit, i.e. by
+    // two byte lanes. mvmd_dslli shifts the lanes and pulls the *previous pack's* top
+    // lanes into the vacated ones, so the first code unit's predecessor slot receives
+    // the incoming carry automatically -- the cross-pack carry needs no scalar bit.
+    Value * const prevHi = b.mvmd_dslli(8, isHi8, prevHiPhi, 2);
+
+    // ODD_ONE_MASK keeps only the high-byte position of each code unit and leaves a
+    // single set bit there, so one block popcount is exactly the number of ill-formed
+    // code units in this pack.
+    //
+    // This replaces the two hsimd_signmask(8) calls the previous version made here.
+    // On AArch64 that operation has no NEON lowering in IDISA and expanded to ~16
+    // lane extractions plus scalar bit assembly per call, which dominated the loop
+    // (see docs/simd_regression_investigation.md).
+    Value * const mismatch = b.simd_and(b.simd_xor(isLo8, prevHi), ODD_ONE_MASK);
+    Value * const markNext = b.CreateAdd(
+        markPhi, b.CreateZExtOrTrunc(b.bitblock_popcount(mismatch), sizeTy));
+
+    Value * const nextP = b.CreateAdd(p, ONE);
+    p->addIncoming(nextP, b.GetInsertBlock());
+    prevHiPhi->addIncoming(isHi8, b.GetInsertBlock());   // this pack's mask carries forward
+    markPhi->addIncoming(markNext, b.GetInsertBlock());
+    b.CreateCondBr(b.CreateICmpNE(nextP, fullPacks), simdLoop, afterSIMD);
+
+    // --- After the SIMD loop: recover the carry (pending high) and marker count ---
+    b.SetInsertPoint(afterSIMD);
+    PHINode * const carryFinal = b.CreatePHI(byteVecTy, 2);
+    carryFinal->addIncoming(carryInit, entry);       // fullPacks == 0 -> carry is pendIn
+    carryFinal->addIncoming(isHi8, simdLoop);        // else -> last pack's high-surrogate mask
+    PHINode * const markFinal = b.CreatePHI(sizeTy, 2);
+    markFinal->addIncoming(ZERO, entry);
+    markFinal->addIncoming(markNext, simdLoop);
+
+    // The pending-high state is the high-surrogate flag of the last complete code unit,
+    // i.e. the last high-byte lane of the final pack's mask. This is the only lane
+    // extraction in the whole SIMD path, and it happens once per invocation -- not once
+    // per pack.
+    Value * const lastHiByte = b.mvmd_extract(8, carryFinal, HIGH_BYTE_POS);
+    Value * const carryBool = b.CreateICmpNE(lastHiByte, ConstantInt::get(i8Ty, 0));
+
+    // --- Scalar tail: complete code units after the last full SIMD pack ---
+    // Byte-oriented like the fast path: read the high byte at offset 2*idx+1 (LE)
+    // directly, so the tail is also independent of host lane order. Raw-pointer
+    // reads stay within avail under Linear(), exactly like the scalar oracle.
+    Value * const processed = b.getProcessedItemCount("byteStream");
+    Value * const i8base = b.getRawInputPointer("byteStream", processed);
+
+    BasicBlock * const tailLoop = b.CreateBasicBlock("tailLoop");
+    BasicBlock * const tailDone = b.CreateBasicBlock("tailDone");
+    b.CreateCondBr(b.CreateICmpNE(tailBase, validUnits), tailLoop, tailDone);
+
+    b.SetInsertPoint(tailLoop);
+    PHINode * const idx = b.CreatePHI(sizeTy, 2);
+    PHINode * const tErr = b.CreatePHI(sizeTy, 2);
+    PHINode * const pend = b.CreatePHI(i1Ty, 2);
+    idx->addIncoming(tailBase, afterSIMD);
+    tErr->addIncoming(ZERO, afterSIMD);
+    pend->addIncoming(carryBool, afterSIMD);
+
+    Value * const hiOff = b.CreateAdd(b.CreateShl(idx, ONE), b.getSize(HB));  // 2*idx + HB (high byte)
+    Value * const hiByte = b.CreateLoad(i8Ty, b.CreateGEP(i8Ty, i8base, hiOff));
+    Value * const tMasked = b.CreateAnd(hiByte, b.getInt8(0xFC));
+    Value * const tIsHigh = b.CreateICmpEQ(tMasked, b.getInt8(0xD8));
+    Value * const tIsLow  = b.CreateICmpEQ(tMasked, b.getInt8(0xDC));
+    Value * const errAdd = b.CreateSelect(tIsLow,
+                                          b.CreateSelect(pend, ZERO, ONE),
+                                          b.CreateSelect(pend, ONE, ZERO));
+    Value * const tErrNext = b.CreateAdd(tErr, errAdd);
+    Value * const pendNext = tIsHigh;
+    Value * const idxNext = b.CreateAdd(idx, ONE);
+    idx->addIncoming(idxNext, tailLoop);
+    tErr->addIncoming(tErrNext, tailLoop);
+    pend->addIncoming(pendNext, tailLoop);
+    b.CreateCondBr(b.CreateICmpNE(idxNext, validUnits), tailLoop, tailDone);
+
+    b.SetInsertPoint(tailDone);
+    PHINode * const tErrFinal = b.CreatePHI(sizeTy, 2);
+    PHINode * const pendFinal = b.CreatePHI(i1Ty, 2);
+    tErrFinal->addIncoming(ZERO, afterSIMD);
+    tErrFinal->addIncoming(tErrNext, tailLoop);
+    pendFinal->addIncoming(carryBool, afterSIMD);
+    pendFinal->addIncoming(pendNext, tailLoop);
+
+    // errAccum accumulates full-block marker popcounts + scalar-tail errors across
+    // all segments, WITHOUT the EOF adjustments (so they are never double-added).
+    Value * const newErrAccum = b.CreateAdd(errAccumIn, b.CreateAdd(markFinal, tErrFinal));
+
+    Value * const atEOF = b.isFinal();
+    Value * const danglingHigh = b.CreateAnd(atEOF, pendFinal);                             // trailing high, no successor
+    Value * const oddByte = b.CreateAnd(atEOF, b.CreateICmpNE(b.CreateAnd(avail, ONE), ZERO)); // incomplete final unit
+    Value * errorTotal = b.CreateAdd(newErrAccum, b.CreateZExt(danglingHigh, sizeTy));
+    errorTotal = b.CreateAdd(errorTotal, b.CreateZExt(oddByte, sizeTy));
+
+    b.setScalarField("errAccum", newErrAccum);
+    // Store the pending-high flag from the last VALID unit; clear it at EOF.
+    Value * const pendStore = b.CreateSelect(atEOF, b.getInt1(false), pendFinal);
+    b.setScalarField("pendingHigh", pendStore);
+    // Output scalar written here in generateMultiBlockLogic (final segment wins),
+    // mirroring the scalar UTF16ValidatorKernel -- the proven in-file pattern for a
+    // stream-consuming kernel that terminates the pipeline with a scalar output.
+    b.setScalarField("errorCount", errorTotal);
+}
+
+// ===========================================================================
+// errorMarks producer -- PROTOTYPE (issue #32).
+// ===========================================================================
+//
+// This kernel is an ADDITION, not a replacement. The count-only paths above
+// (scalar oracle and UTF16ValidatorSIMDKernel) are untouched and remain the
+// default; --emit-error-marks selects this one instead. Nothing here repairs
+// anything, and there is no TwoLevelScanKernel subclass.
+//
+// It emits a real Parabix bitstream:
+//
+//     errorMarks : StreamSet(1)     -- ONE BIT PER UTF-16 CODE UNIT
+//     bit i == 1  iff  code unit i is ITSELF ill-formed
+//
+// Why this needs a different rule from the count-only kernel
+// ---------------------------------------------------------
+// UTF16ValidatorSIMDKernel counts mismatch[k] = isLow[k] XOR isHigh[k-1]. That
+// is exact for COUNTING, but it registers a lone high surrogate at its
+// SUCCESSOR's position: for D800 0041 it flags unit 1, which is the letter 'A'
+// -- a perfectly well-formed code unit. A consumer told to look at unit 1 would
+// be looking at the wrong code unit. A position-accurate marker must instead be
+//
+//     bad[k] = (isLow[k]  AND NOT isHigh[k-1])     // low with no high before it
+//           OR (isHigh[k] AND NOT isLow[k+1])      // high with no low after it
+//
+// and that needs code unit k+1 -- i.e. a ONE-CODE-UNIT LOOKAHEAD, which the
+// count-only kernel does not need. See docs/parabix_errormarks_producer.md.
+//
+// LookAhead(2): the rule reads the high byte of code unit k+1, at byte offset
+// 2k+3. For the last code unit of a segment that is up to 2 bytes past the
+// accessible extent, so the input declares LookAhead(2) (attributes.h:25-45):
+// the pipeline guarantees those items are valid and linearly contiguous, and
+// ZERO-FILLS them on the final call. Zero bytes are not low surrogates, so a
+// high surrogate at EOF marks itself -- exactly the semantics we want, with no
+// EOF special case. On a NON-final segment the lookahead holds the real next
+// segment's bytes, so a valid surrogate pair straddling a segment boundary is
+// correctly NOT marked.
+//
+// pendingHigh: unchanged in spirit from the count-only kernel. The previous
+// pack's isHi8 mask is carried as a VECTOR and shifted in with mvmd_dslli, and a
+// 1-bit pendingHigh InternalScalar threads that state across segments.
+//
+// Bytes -> bits reduction: NO hsimd_signmask(8). Issue #38 showed it has no
+// AArch64 lowering in IDISA and scalarises into ~16 lane extractions per call.
+// Instead each pack's marker bytes are weighted (simd_and with a constant) and
+// each 64-bit lane is OR-folded to 4 bits after ONE mvmd_extract(64, ...) --
+// one lane extraction per 4 code units instead of 16 per 8. This is the same
+// family of operations as the vector_pack_reduce prototype
+// (docs/llmask_generation_prototype.md), though deliberately the simple,
+// obviously-correct form rather than the fully optimised one.
+//
+// This kernel does strictly more work than the count-only kernel (it writes a
+// bitstream). It is NOT expected to be faster, and no such claim is made.
+class UTF16ErrorMarksKernel final : public MultiBlockKernel {
+public:
+    UTF16ErrorMarksKernel(LLVMTypeSystemInterface & ts, StreamSet * byteStream,
+                          StreamSet * errorMarks, Scalar * errorCount, bool bigEndian = false);
+private:
+    void generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const numOfStrides) override;
+    const bool mBigEndian;
+};
+
+UTF16ErrorMarksKernel::UTF16ErrorMarksKernel(LLVMTypeSystemInterface & ts, StreamSet * byteStream,
+                                             StreamSet * errorMarks, Scalar * errorCount, bool bigEndian)
+: MultiBlockKernel(ts, bigEndian ? "utf16errormarks_be" : "utf16errormarks",
+// input: raw bytes, 2 per code unit. FixedRate(2) against the FixedRate(1) output gives
+// accessible(bytes) == 2 * writable(marks). Linear() for the raw byte reads; LookAhead(2)
+// for the k+1 term of the marker rule.
+{Binding{"byteStream", byteStream, FixedRate(2), {Linear(), LookAhead(2)}}},
+// output: one bit per code unit.
+{Binding{"errorMarks", errorMarks, FixedRate(1)}},
+// input scalars
+{},
+// output scalar: total ill-formed code units == popcount(errorMarks) + oddTrailingByte.
+{Binding{"errorCount", errorCount}},
+// internal (persistent) scalars carried across segments
+{InternalScalar{ts.getInt1Ty(), "pendingHigh"},
+ InternalScalar{ts.getSizeTy(), "errAccum"}})
+, mBigEndian(bigEndian) {
+
+}
+
+void UTF16ErrorMarksKernel::generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const /* numOfStrides */) {
+    Type * const sizeTy = b.getSizeTy();
+    Type * const i1Ty = b.getInt1Ty();
+    Type * const i8Ty = b.getInt8Ty();
+    Type * const i64Ty = b.getInt64Ty();
+
+    // High-byte lane offset within a code unit: 2k+1 for UTF-16LE (HB=1), 2k for UTF-16BE
+    // (HB=0). Every endian-specific quantity below reduces to this offset. LE is unchanged.
+    const unsigned HB = mBigEndian ? 0u : 1u;
+
+    const unsigned BITS = b.getBitBlockWidth();
+    const unsigned BYTES_PER_PACK = BITS / 8;              // bytes in one SIMD pack
+    const unsigned UNITS_PER_PACK = BITS / 16;             // code units per pack
+    const unsigned HIGH_BYTE_POS = BYTES_PER_PACK - 2 + HB;   // last high-byte lane of a pack
+    const unsigned LANES_PER_PACK = BYTES_PER_PACK / 8;    // 64-bit lanes in a pack
+    const unsigned WORDS_PER_BLOCK = BITS / 64;            // 64-bit words in one marker block
+    // One marker block holds BITS code units == 2*BITS bytes == 16 packs, for every BITS.
+    const unsigned PACKS_PER_BLOCK = (2 * BITS) / BYTES_PER_PACK;   // == 16
+
+    FixedVectorType * const byteVecTy = FixedVectorType::get(i8Ty, BYTES_PER_PACK);
+    FixedVectorType * const wordVecTy = FixedVectorType::get(i64Ty, WORDS_PER_BLOCK);
+
+    // WEIGHTS: at the high-byte lane of each code unit, the bit that code unit owns within
+    // its 64-bit lane. Byte lane 8L+2j+HB (code unit 4L+j) gets weight 1<<j, j in [0,4).
+    // The other-parity (low-byte) lanes get 0, which also masks off the garbage that the fw=8
+    // compares leave there -- a low byte can coincidentally equal 0xD8/0xDC (e.g. 0x00D8).
+    std::vector<Constant *> weightLanes(BYTES_PER_PACK);
+    for (unsigned pos = 0; pos < BYTES_PER_PACK; ++pos) {
+        const bool isHighLane = (pos & 1u) == HB;
+        const unsigned j = ((pos % 8) - HB) / 2;           // only meaningful for high-byte lanes
+        weightLanes[pos] = ConstantInt::get(i8Ty, isHighLane ? (1u << j) : 0u);
+    }
+    Constant * const WEIGHTS = ConstantVector::get(weightLanes);
+
+    Value * const ZERO = b.getSize(0);
+    Value * const ONE = b.getSize(1);
+
+    // Byte-oriented fw=8 classification splats (identical to the count-only kernel).
+    Value * const splatFC = b.simd_fill(8, b.getInt8(0xFC));
+    Value * const splatD8 = b.simd_fill(8, b.getInt8(0xD8));
+    Value * const splatDC = b.simd_fill(8, b.getInt8(0xDC));
+
+    Value * const avail = b.getAccessibleItemCount("byteStream");
+    Value * const validUnits = b.CreateLShr(avail, ONE);
+    Value * const fullBlocks = b.CreateUDiv(validUnits, b.getSize(BITS));   // whole marker blocks
+    Value * const tailBase = b.CreateMul(fullBlocks, b.getSize(BITS));      // first tail code unit
+
+    Value * const pendIn = b.getScalarField("pendingHigh");
+    Value * const errAccumIn = b.getScalarField("errAccum");
+
+    Value * const processed = b.getProcessedItemCount("byteStream");
+    Value * const i8base = b.getRawInputPointer("byteStream", processed);
+
+    // The carry: the previous pack's high-surrogate byte mask. Only its last high-byte lane
+    // matters, so the incoming pendingHigh is injected there as 0xFF (what simd_eq produces).
+    Value * const pendByte = b.CreateSExt(pendIn, i8Ty);
+    Value * const carryInit = b.CreateInsertElement(ConstantAggregateZero::get(byteVecTy),
+                                                    pendByte, b.getInt32(HIGH_BYTE_POS));
+
+    BasicBlock * const entry = b.GetInsertBlock();
+    BasicBlock * const blockLoop = b.CreateBasicBlock("markBlockLoop");
+    BasicBlock * const afterBlocks = b.CreateBasicBlock("afterMarkBlocks");
+    b.CreateCondBr(b.CreateICmpNE(fullBlocks, ZERO), blockLoop, afterBlocks);
+
+    // --- One full marker block (BITS code units) per iteration. -----------------------
+    b.SetInsertPoint(blockLoop);
+    PHINode * const blk = b.CreatePHI(sizeTy, 2);
+    PHINode * const prevHiPhi = b.CreatePHI(byteVecTy, 2);
+    PHINode * const errPhi = b.CreatePHI(sizeTy, 2);
+    blk->addIncoming(ZERO, entry);
+    prevHiPhi->addIncoming(carryInit, entry);
+    errPhi->addIncoming(ZERO, entry);
+
+    Value * const packBase = b.CreateMul(blk, b.getSize(PACKS_PER_BLOCK));
+    Value * carry = prevHiPhi;
+    std::vector<Value *> words(WORDS_PER_BLOCK, ConstantInt::get(i64Ty, 0));
+
+    for (unsigned sub = 0; sub < PACKS_PER_BLOCK; ++sub) {
+        Value * const P = b.CreateAdd(packBase, b.getSize(sub));
+        // Stream-pack addressing for a StreamSet(1,8): 8 packs per stream block.
+        Value * const packIndex = b.CreateTrunc(b.CreateAnd(P, b.getSize(7)), b.getInt32Ty());
+        Value * const blockOffset = b.CreateLShr(P, b.getSize(3));
+        Value * const pack = b.loadInputStreamPack("byteStream", ZERO, packIndex, blockOffset);
+
+        Value * const bytes = b.fwCast(8, pack);
+        Value * const masked = b.simd_and(bytes, splatFC);
+        Value * const isHi8 = b.simd_eq(8, masked, splatD8);
+        Value * const isLo8 = b.simd_eq(8, masked, splatDC);
+
+        // prevHigh[k] = isHigh[k-1 code unit] = isHi8 advanced by two byte lanes, with the
+        // previous pack's top lanes pulled into the vacated ones.
+        Value * const prevHi = b.mvmd_dslli(8, isHi8, carry, 2);
+
+        // nextLow[k] = isLow[k+1 code unit] = isLo8 shifted DOWN by two byte lanes. Only the
+        // LAST high-byte lane needs data from beyond this pack, and it needs exactly ONE byte:
+        // the high byte of the next pack's first code unit, at raw offset
+        // (P+1)*BYTES_PER_PACK + HB. That is at most `avail + 1`, which LookAhead(2) covers --
+        // and which the pipeline zero-fills on the final call, so a trailing high surrogate
+        // marks itself with no EOF special case.
+        Value * const laOff = b.CreateAdd(b.CreateMul(b.CreateAdd(P, ONE),
+                                                      b.getSize(BYTES_PER_PACK)), b.getSize(HB));
+        Value * const laByte = b.CreateLoad(i8Ty, b.CreateGEP(i8Ty, i8base, laOff));
+        Value * const laIsLow = b.CreateICmpEQ(b.CreateAnd(laByte, b.getInt8(0xFC)),
+                                               b.getInt8(0xDC));
+        // mvmd_dslli(fw, a, b, s): result[i] = a[i-s] for i>=s, else b[fieldCount-s+i].
+        // With s = BYTES_PER_PACK-2: result[i] = isLo8[i+2] for i < BYTES_PER_PACK-2, and the
+        // top two lanes [BYTES_PER_PACK-2, BYTES_PER_PACK-1] come from laVec[0], laVec[1].
+        // The high-byte lane of the last code unit is BYTES_PER_PACK-2+HB, which reads
+        // laVec[HB] -- so the lookahead byte is inserted at lane HB.
+        Value * const laVec = b.CreateInsertElement(ConstantAggregateZero::get(byteVecTy),
+                                                    b.CreateSExt(laIsLow, i8Ty), b.getInt32(HB));
+        Value * const nextLo = b.mvmd_dslli(8, laVec, isLo8, BYTES_PER_PACK - 2);
+
+        // bad[k] = (isLow[k] & !isHigh[k-1]) | (isHigh[k] & !isLow[k+1])
+        Value * const bad = b.simd_or(b.simd_and(isLo8, b.simd_not(prevHi)),
+                                      b.simd_and(isHi8, b.simd_not(nextLo)));
+
+        // Reduce marker bytes to marker bits without hsimd_signmask: weight the high-byte
+        // lanes, then OR-fold each 64-bit lane (one mvmd_extract per 4 code units).
+        Value * const weighted = b.simd_and(bad, WEIGHTS);
+        for (unsigned L = 0; L < LANES_PER_PACK; ++L) {
+            Value * x = b.CreateZExtOrTrunc(b.mvmd_extract(64, weighted, L), i64Ty);
+            x = b.CreateOr(x, b.CreateLShr(x, ConstantInt::get(i64Ty, 32)));
+            x = b.CreateOr(x, b.CreateLShr(x, ConstantInt::get(i64Ty, 16)));
+            x = b.CreateOr(x, b.CreateLShr(x, ConstantInt::get(i64Ty, 8)));
+            x = b.CreateAnd(x, ConstantInt::get(i64Ty, 0x0F));   // 4 code units, 4 bits
+            const unsigned bitOff = sub * UNITS_PER_PACK + L * 4;
+            const unsigned w = bitOff / 64;
+            const unsigned sh = bitOff % 64;
+            words[w] = b.CreateOr(words[w], b.CreateShl(x, ConstantInt::get(i64Ty, sh)));
+        }
+        carry = isHi8;
+    }
+
+    // Assemble and store the marker block; count the bits we actually emitted, so errorCount
+    // is by construction popcount(errorMarks) + oddTrailingByte.
+    Value * blockVec = ConstantAggregateZero::get(wordVecTy);
+    Value * errAdd = ConstantInt::get(sizeTy, 0);
+    for (unsigned w = 0; w < WORDS_PER_BLOCK; ++w) {
+        blockVec = b.CreateInsertElement(blockVec, words[w], b.getInt32(w));
+        errAdd = b.CreateAdd(errAdd, b.CreateZExtOrTrunc(
+            b.CreateUnaryIntrinsic(Intrinsic::ctpop, words[w]), sizeTy));
+    }
+    b.storeOutputStreamBlock("errorMarks", ZERO, blk,
+                             b.CreateBitCast(blockVec, b.getBitBlockType()));
+
+    Value * const errNext = b.CreateAdd(errPhi, errAdd);
+    Value * const nextBlk = b.CreateAdd(blk, ONE);
+    blk->addIncoming(nextBlk, b.GetInsertBlock());
+    prevHiPhi->addIncoming(carry, b.GetInsertBlock());
+    errPhi->addIncoming(errNext, b.GetInsertBlock());
+    b.CreateCondBr(b.CreateICmpNE(nextBlk, fullBlocks), blockLoop, afterBlocks);
+
+    // --- After the full blocks: recover the carry and the running count -----------------
+    b.SetInsertPoint(afterBlocks);
+    PHINode * const carryFinal = b.CreatePHI(byteVecTy, 2);
+    carryFinal->addIncoming(carryInit, entry);
+    carryFinal->addIncoming(carry, blockLoop);
+    PHINode * const errFinal = b.CreatePHI(sizeTy, 2);
+    errFinal->addIncoming(ZERO, entry);
+    errFinal->addIncoming(errNext, blockLoop);
+
+    Value * const lastHiByte = b.mvmd_extract(8, carryFinal, HIGH_BYTE_POS);
+    Value * const carryBool = b.CreateICmpNE(lastHiByte, ConstantInt::get(i8Ty, 0));
+
+    // --- Tail: the fewer-than-BITS code units after the last full marker block ----------
+    // Byte-oriented and scalar. It builds the final PARTIAL marker block bit by bit in an
+    // alloca and stores it, leaving the bits past the last code unit zero -- so a consumer
+    // that reads whole blocks never sees a phantom marker.
+    Value * const tailWords = b.CreateAlloca(wordVecTy);
+    b.CreateStore(ConstantAggregateZero::get(wordVecTy), tailWords);
+    Value * const wordArray = b.CreatePointerCast(tailWords, i64Ty->getPointerTo());
+
+    BasicBlock * const tailLoop = b.CreateBasicBlock("markTailLoop");
+    BasicBlock * const tailDone = b.CreateBasicBlock("markTailDone");
+    Value * const hasTail = b.CreateICmpNE(tailBase, validUnits);
+    b.CreateCondBr(hasTail, tailLoop, tailDone);
+
+    b.SetInsertPoint(tailLoop);
+    PHINode * const idx = b.CreatePHI(sizeTy, 2);
+    PHINode * const tErr = b.CreatePHI(sizeTy, 2);
+    PHINode * const pend = b.CreatePHI(i1Ty, 2);
+    idx->addIncoming(tailBase, afterBlocks);
+    tErr->addIncoming(ZERO, afterBlocks);
+    pend->addIncoming(carryBool, afterBlocks);
+
+    // High byte of code unit idx (2*idx+HB) and of code unit idx+1 (2*idx+HB+2). The latter is
+    // at most avail+1, inside the LookAhead(2) region, and zero at EOF.
+    Value * const hiOff = b.CreateAdd(b.CreateShl(idx, ONE), b.getSize(HB));
+    Value * const hiByte = b.CreateLoad(i8Ty, b.CreateGEP(i8Ty, i8base, hiOff));
+    Value * const nxByte = b.CreateLoad(i8Ty, b.CreateGEP(i8Ty, i8base,
+                                                          b.CreateAdd(hiOff, b.getSize(2))));
+    Value * const tMasked = b.CreateAnd(hiByte, b.getInt8(0xFC));
+    Value * const tIsHigh = b.CreateICmpEQ(tMasked, b.getInt8(0xD8));
+    Value * const tIsLow  = b.CreateICmpEQ(tMasked, b.getInt8(0xDC));
+    Value * const tNextLow = b.CreateICmpEQ(b.CreateAnd(nxByte, b.getInt8(0xFC)), b.getInt8(0xDC));
+    Value * const tBad = b.CreateOr(b.CreateAnd(tIsLow, b.CreateNot(pend)),
+                                    b.CreateAnd(tIsHigh, b.CreateNot(tNextLow)));
+
+    // Set bit (idx - tailBase) of the partial block.
+    Value * const local = b.CreateSub(idx, tailBase);
+    Value * const wIdx = b.CreateLShr(local, b.getSize(6));
+    Value * const bIdx = b.CreateAnd(local, b.getSize(63));
+    Value * const wPtr = b.CreateGEP(i64Ty, wordArray, wIdx);
+    Value * const wOld = b.CreateLoad(i64Ty, wPtr);
+    Value * const bit = b.CreateShl(b.CreateZExt(tBad, i64Ty),
+                                    b.CreateZExtOrTrunc(bIdx, i64Ty));
+    b.CreateStore(b.CreateOr(wOld, bit), wPtr);
+
+    Value * const tErrNext = b.CreateAdd(tErr, b.CreateZExt(tBad, sizeTy));
+    Value * const idxNext = b.CreateAdd(idx, ONE);
+    idx->addIncoming(idxNext, tailLoop);
+    tErr->addIncoming(tErrNext, tailLoop);
+    pend->addIncoming(tIsHigh, tailLoop);
+    b.CreateCondBr(b.CreateICmpNE(idxNext, validUnits), tailLoop, tailDone);
+
+    b.SetInsertPoint(tailDone);
+    PHINode * const tErrTotal = b.CreatePHI(sizeTy, 2);
+    PHINode * const pendFinal = b.CreatePHI(i1Ty, 2);
+    tErrTotal->addIncoming(ZERO, afterBlocks);
+    tErrTotal->addIncoming(tErrNext, tailLoop);
+    pendFinal->addIncoming(carryBool, afterBlocks);
+    pendFinal->addIncoming(tIsHigh, tailLoop);
+
+    // Store the partial block only if there is one.
+    BasicBlock * const storeTail = b.CreateBasicBlock("storeTailBlock");
+    BasicBlock * const finish = b.CreateBasicBlock("markFinish");
+    b.CreateCondBr(hasTail, storeTail, finish);
+
+    b.SetInsertPoint(storeTail);
+    Value * const tailBlock = b.CreateLoad(wordVecTy, tailWords);
+    b.storeOutputStreamBlock("errorMarks", ZERO, fullBlocks,
+                             b.CreateBitCast(tailBlock, b.getBitBlockType()));
+    b.CreateBr(finish);
+
+    b.SetInsertPoint(finish);
+
+    // errAccum = every marker bit emitted so far, across all segments. A dangling final high
+    // surrogate needs NO EOF adjustment here: the zero-filled lookahead already made the rule
+    // mark it in the stream. The odd trailing byte is the one error with no code-unit
+    // position, so it -- and only it -- is added at EOF.
+    Value * const newErrAccum = b.CreateAdd(errAccumIn, b.CreateAdd(errFinal, tErrTotal));
+    Value * const atEOF = b.isFinal();
+    Value * const oddByte = b.CreateAnd(atEOF,
+                                        b.CreateICmpNE(b.CreateAnd(avail, ONE), ZERO));
+    Value * const errorTotal = b.CreateAdd(newErrAccum, b.CreateZExt(oddByte, sizeTy));
+
+    b.setScalarField("errAccum", newErrAccum);
+    b.setScalarField("pendingHigh", b.CreateSelect(atEOF, b.getInt1(false), pendFinal));
+    b.setScalarField("errorCount", errorTotal);
+}
+
+// ===========================================================================
+// errorMarks consumer -- PROTOTYPE, position printer (issue #32).
+// ===========================================================================
+//
+// A deliberately minimal sink: it reads the errorMarks bitstream and prints the
+// code-unit index of every set bit, using the SAME ctz / reset-lowest-bit inner
+// loop as Parabix's TwoLevelScanKernel (CreateCountForwardZeroes and
+// CreateResetLowestBit, lib/kernel/scan/base.cpp:221). It exists ONLY so the
+// contents of the emitted bitstream can be diffed against the standalone
+// prototypes; it is NOT a TwoLevelScanKernel subclass, it builds no maskHL, and
+// it skips nothing. Selected by --print-positions.
+//
+// Positions are printed with CallPrintInt (hexadecimal). Under multiple pipeline
+// threads segments may interleave, so callers must sort; the test script uses
+// -thread-num=1 and sorts anyway.
+class ErrorMarkPositionKernel final : public MultiBlockKernel {
+public:
+    ErrorMarkPositionKernel(LLVMTypeSystemInterface & ts, StreamSet * errorMarks);
+private:
+    void generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const numOfStrides) override;
+};
+
+ErrorMarkPositionKernel::ErrorMarkPositionKernel(LLVMTypeSystemInterface & ts, StreamSet * errorMarks)
+: MultiBlockKernel(ts, "utf16errormarkpositions",
+{Binding{"errorMarks", errorMarks, FixedRate(1)}},
+{}, {}, {}, {}) {
+    // This kernel has no stream or scalar outputs -- its only result is what it prints. Without
+    // SideEffecting() the pipeline is free to consider it dead and never schedule it, and it
+    // silently prints nothing (attributes.h:280-284: "a kernel that reports its result through
+    // StdOut/StdErr should be marked as SideEffecting").
+    addAttribute(SideEffecting());
+}
+
+void ErrorMarkPositionKernel::generateMultiBlockLogic(KernelBuilder & b, llvm::Value * const /* numOfStrides */) {
+    Type * const sizeTy = b.getSizeTy();
+    Type * const i64Ty = b.getInt64Ty();
+
+    const unsigned BITS = b.getBitBlockWidth();
+    const unsigned WORDS_PER_BLOCK = BITS / 64;
+
+    Value * const ZERO = b.getSize(0);
+    Value * const ONE = b.getSize(1);
+    Value * const processed = b.getProcessedItemCount("errorMarks");
+    Value * const accessible = b.getAccessibleItemCount("errorMarks");
+    // Blocks that contain at least one accessible marker bit.
+    Value * const numBlocks = b.CreateUDiv(b.CreateAdd(accessible, b.getSize(BITS - 1)),
+                                           b.getSize(BITS));
+
+    BasicBlock * const entry = b.GetInsertBlock();
+    BasicBlock * const blockLoop = b.CreateBasicBlock("posBlockLoop");
+    BasicBlock * const done = b.CreateBasicBlock("posDone");
+    b.CreateCondBr(b.CreateICmpNE(numBlocks, ZERO), blockLoop, done);
+
+    b.SetInsertPoint(blockLoop);
+    PHINode * const blk = b.CreatePHI(sizeTy, 2);
+    blk->addIncoming(ZERO, entry);
+    Value * const marks = b.loadInputStreamBlock("errorMarks", ZERO, blk);
+
+    for (unsigned w = 0; w < WORDS_PER_BLOCK; ++w) {
+        Value * const localBase = b.CreateAdd(b.CreateMul(blk, b.getSize(BITS)),
+                                              b.getSize(w * 64));
+        // Mask off any bits at or beyond the accessible extent: on the final partial block
+        // the producer left them zero, but a circular buffer may still hold stale bits.
+        Value * const inRange = b.CreateICmpUGT(accessible, localBase);
+        Value * const rem = b.CreateSelect(inRange, b.CreateSub(accessible, localBase), ZERO);
+        Value * const full = b.CreateICmpUGE(rem, b.getSize(64));
+        Value * const partialMask = b.CreateSub(
+            b.CreateShl(ConstantInt::get(i64Ty, 1), b.CreateZExtOrTrunc(rem, i64Ty)),
+            ConstantInt::get(i64Ty, 1));
+        Value * const mask = b.CreateSelect(full, ConstantInt::get(i64Ty, ~0ULL), partialMask);
+        Value * const word0 = b.CreateAnd(
+            b.CreateZExtOrTrunc(b.mvmd_extract(64, marks, w), i64Ty), mask);
+
+        BasicBlock * const bitLoop = b.CreateBasicBlock("posBitLoop");
+        BasicBlock * const bitDone = b.CreateBasicBlock("posBitDone");
+        BasicBlock * const wordEntry = b.GetInsertBlock();
+        b.CreateCondBr(b.CreateICmpNE(word0, ConstantInt::get(i64Ty, 0)), bitLoop, bitDone);
+
+        b.SetInsertPoint(bitLoop);
+        PHINode * const word = b.CreatePHI(i64Ty, 2);
+        word->addIncoming(word0, wordEntry);
+        // The TwoLevelScanKernel inner loop: ctz to the next set bit, then reset it.
+        Value * const bit = b.CreateZExtOrTrunc(b.CreateCountForwardZeroes(word), sizeTy);
+        Value * const pos = b.CreateAdd(b.CreateAdd(processed, localBase), bit);
+        b.CallPrintInt("errpos", pos, CBuilder::STD_FD::STD_OUT);
+        Value * const wordNext = b.CreateResetLowestBit(word);
+        word->addIncoming(wordNext, b.GetInsertBlock());
+        b.CreateCondBr(b.CreateICmpNE(wordNext, ConstantInt::get(i64Ty, 0)), bitLoop, bitDone);
+
+        b.SetInsertPoint(bitDone);
+    }
+
+    Value * const nextBlk = b.CreateAdd(blk, ONE);
+    blk->addIncoming(nextBlk, b.GetInsertBlock());
+    b.CreateCondBr(b.CreateICmpNE(nextBlk, numBlocks), blockLoop, done);
+
+    b.SetInsertPoint(done);
+}
+
+// ===========================================================================
+// errorMarks consumer -- TwoLevelScanKernel subclass (issue #39).
+// ===========================================================================
+//
+// This is the real consumer side. It is a DIRECT SUBCLASS of Parabix's
+// TwoLevelScanKernel (include/kernel/scan/base.h), so the two-level scan
+// machinery -- high-level index (maskHL) construction, clean-region skipping,
+// and ctz / reset-lowest-bit scanning at both levels -- is Parabix's own code,
+// not a reimplementation. This kernel only supplies the leaf action: print the
+// code-unit position of each set bit.
+//
+// What the base class does for us (lib/kernel/scan/base.cpp:221-390):
+//   * generateIndexComputation builds, per stride, a size_t "maskHL" whose bit w
+//     is set iff scanword w of errorMarks is nonzero -- via simd_any(64, block)
+//     + hsimd_signmask(64, ...). At scanWordWidth=64 on a 128-bit block that is
+//     TWO lanes per block, so it does NOT hit the fw=8 signmask problem issue #38
+//     found on AArch64 (see docs/two_level_scan_design.md).
+//   * strideLogic does CreateLikelyCondBr(metaMask != 0, ...), so a stride whose
+//     maskHL is all-zero (a clean 4096-code-unit region) is skipped with a single
+//     branch; then CreateCountForwardZeroes walks only the dirty scanwords, and
+//     within each, only the set bits.
+//   * generateProcessingLogic is called once per set bit with the ABSOLUTE
+//     code-unit position (itemPos) already computed.
+//
+// scanWordWidth = 64: maxScanBlocks = 64 bits / (BITS/64 scanwords per block).
+// On a 128-bit block that is 32 blocks/stride = 64 scanwords x 64 bits = 4096
+// code units per stride -- exactly the region size from issues #30/#31.
+//
+// No loop variables are needed: locating positions is stateless, so the LoopVar
+// list is empty, initialize() is trivial, and wordPrologueLogic() is a no-op.
+//
+// It prints the same "errpos = <hex>" lines as the issue #32 debug printer -- the
+// positions are identical by construction -- so both are diffable against
+// benchmarks/llmask_reference.py --positions. The distinction is the SCAN
+// STRATEGY (this one skips clean regions; the #32 printer visits every block).
+// SideEffecting() is required, exactly as for the #32 printer: a kernel whose
+// only result is what it prints is otherwise considered dead and never scheduled
+// (attributes.h:280-284).
+class UTF16ErrorMarkScanKernel final : public TwoLevelScanKernel {
+public:
+    UTF16ErrorMarkScanKernel(LLVMTypeSystemInterface & ts, StreamSet * errorMarks)
+    : TwoLevelScanKernel(ts, "utf16errormarkscan", /*scanWordWidth*/ 64,
+                         /*scanStreamName*/ "errorMarks", /*loopVars*/ {}) {
+        mInputStreamSets.push_back(Binding{"errorMarks", errorMarks});
+        addAttribute(SideEffecting());
+    }
+protected:
+    void initialize(KernelBuilder & /* b */) override {
+        // No loop variables to seed.
+    }
+    void wordPrologueLogic(KernelBuilder & /* b */, llvm::Value * /* absWordPosition */,
+                           std::vector<llvm::Value *> /* indexWord */,
+                           std::vector<llvm::Value *> & /* loopVars */) override {
+        // Nothing to do once per dirty scanword; the leaf action is per set bit.
+    }
+    void generateProcessingLogic(KernelBuilder & b, llvm::Value * absItemPos,
+                                 std::vector<llvm::Value *> & /* loopVars */) override {
+        b.CallPrintInt("errpos", absItemPos, CBuilder::STD_FD::STD_OUT);
+    }
+    void finalize(KernelBuilder & /* b */,
+                  std::vector<llvm::Value *> & /* loopVarFinalValues */) override {
+        // Nothing to flush.
+    }
+};
+
+typedef uint64_t (*utf16validateFunctionType)(const uint32_t fd);
+
+utf16validateFunctionType utf16validatePipelineGen(CPUDriver & driver) {
+    auto P = CreatePipeline(driver, Input<uint32_t>{"fd"}, Output<uint64_t>{"errorCount"});
+    Scalar * const fileDescriptor = P.getInputScalar("fd");
+    StreamSet * const ByteStream = P.CreateStreamSet(1, 8);
+    P.CreateKernelCall<ReadSourceKernel>(fileDescriptor, ByteStream);
+    if (emitErrorMarks) {
+        // Prototype producer path (issue #32). Emits a real StreamSet(1) bitstream, one bit
+        // per code unit, alongside the same errorCount the other paths report. The count-only
+        // kernels above are untouched and are still what --simd and the default select.
+        StreamSet * const ErrorMarks = P.CreateStreamSet(1);
+        P.CreateKernelCall<UTF16ErrorMarksKernel>(ByteStream, ErrorMarks,
+                                                  P.getOutputScalar("errorCount"), bigEndian);
+        if (scanErrorMarks) {
+            // Issue #39 consumer: a real TwoLevelScanKernel subclass that skips clean regions.
+            // Endian-agnostic -- it scans the code-unit-indexed errorMarks bitstream, which the
+            // producer has already made endian-correct.
+            P.CreateKernelCall<UTF16ErrorMarkScanKernel>(ErrorMarks);
+        } else if (printPositions) {
+            // Issue #32 linear debug printer (visits every block).
+            P.CreateKernelCall<ErrorMarkPositionKernel>(ErrorMarks);
+        }
+    } else if (useSIMD) {
+        // SIMD path: one self-contained kernel produces errorCount directly.
+        P.CreateKernelCall<UTF16ValidatorSIMDKernel>(ByteStream, P.getOutputScalar("errorCount"),
+                                                     bigEndian);
+    } else {
+        // Scalar oracle path (default).
+        P.CreateKernelCall<UTF16ValidatorKernel>(ByteStream, P.getOutputScalar("errorCount"),
+                                                 bigEndian);
+    }
+    return reinterpret_cast<utf16validateFunctionType>(P.compile());
+}
+
+void utf16validate(utf16validateFunctionType fn_ptr, const std::string & fileName) {
+    const int fd = open(fileName.c_str(), O_RDONLY);
+    if (LLVM_UNLIKELY(fd == -1)) {
+        std::cerr << "Error: cannot open " << fileName << " for processing. Skipped.\n";
+        return;
+    }
+    const uint64_t errorCount = fn_ptr(fd);
+    close(fd);
+    std::cout << fileName << ": errorCount = " << errorCount << "\n";
+}
+
+int main(int argc, char *argv[]) {
+    codegen::ParseCommandLineOptions(argc, argv, {&utf16validateOptions, codegen::codegen_flags()});
+
+    CPUDriver driver("utf16validate");
+    auto fn_ptr = utf16validatePipelineGen(driver);
+    for (unsigned i = 0; i != inputFiles.size(); ++i) {
+        utf16validate(fn_ptr, inputFiles[i]);
+    }
+    return 0;
+}
